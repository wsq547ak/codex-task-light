{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$PLUGIN_ROOT/scripts/hook_entry.py\"",
            "statusMessage": "Updating traffic light"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$PLUGIN_ROOT/scripts/hook_entry.py\"",
            "statusMessage": "Updating traffic light"
          }
